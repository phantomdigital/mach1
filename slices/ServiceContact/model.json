{
  "id": "service_contact",
  "type": "SharedSlice",
  "name": "Service Contact",
  "description": "Simple contact form for service and specialty pages",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Inline contact form for bottom of service pages",
      "primary": {
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "placeholder": "Interested in this service? Get in touch.",
            "multi": "heading2,heading3,strong,em"
          }
        },
        "subtext": {
          "type": "StructuredText",
          "config": {
            "label": "Subtext",
            "placeholder": "Tell us what you need and our team will get back to you shortly.",
            "multi": "paragraph,strong,em,hyperlink",
            "allowTargetBlank": true
          }
        },
        "submit_button_text": {
          "type": "Text",
          "config": {
            "label": "Submit Button Text",
            "placeholder": "Send Enquiry"
          }
        },
        "margin_top": {
          "type": "Select",
          "config": {
            "label": "Top Margin",
            "placeholder": "Choose top margin",
            "options": ["none", "small", "medium", "large", "extra-large"],
            "default_value": "large"
          }
        }
      },
      "items": {}
    }
  ]
}
